        "$ck-aliases"
      ],
      "synonyms": [
        "menu",
        "commands"
      ],
      "typos": [],
      "skills": [
        "$command-router"
      ],
      "agents": [],
      "scripts": [],
      "artifacts": [
        "docs/command-palette.md"
      ],
      "notes": "Use when you do not remember the shorthand or want the closest safe match.",
      "prompt_wrapper": true
    },
